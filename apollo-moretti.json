        "custom_liquid_nmGLYe": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n{% if product.metafields.custom.angle_1_title != blank or product.metafields.custom.angle_2_title != blank or product.metafields.custom.angle_3_title != blank %}\n<section class=\"product-angles\">\n  \n  {% if product.metafields.custom.angle_1_title != blank %}\n  <div class=\"angle-box\">\n    <div class=\"angle-img\">\n      {% if product.metafields.custom.angle_1_image != blank %}\n        <img src=\"{{ product.metafields.custom.angle_1_image | image_url: width: 600 }}\" alt=\"{{ product.metafields.custom.angle_1_title }}\">\n      {% else %}\n        <img src=\"https://via.placeholder.com/600x450?text=No+Image\" alt=\"No image\">\n      {% endif %}\n    </div>\n    <h3 class=\"angle-title\">{{ product.metafields.custom.angle_1_title }}</h3>\n    {% if product.metafields.custom.angle_1_text != blank %}\n      <p class=\"angle-desc\">{{ product.metafields.custom.angle_1_text }}</p>\n    {% endif %}\n  </div>\n  {% endif %}\n  \n  {% if product.metafields.custom.angle_2_title != blank %}\n  <div class=\"angle-box\">\n    <div class=\"angle-img\">\n      {% if product.metafields.custom.angle_2_image != blank %}\n        <img src=\"{{ product.metafields.custom.angle_2_image | image_url: width: 600 }}\" alt=\"{{ product.metafields.custom.angle_2_title }}\">\n      {% else %}\n        <img src=\"https://via.placeholder.com/600x450?text=No+Image\" alt=\"No image\">\n      {% endif %}\n    </div>\n    <h3 class=\"angle-title\">{{ product.metafields.custom.angle_2_title }}</h3>\n    {% if product.metafields.custom.angle_2_text != blank %}\n      <p class=\"angle-desc\">{{ product.metafields.custom.angle_2_text }}</p>\n    {% endif %}\n  </div>\n  {% endif %}\n  \n  {% if product.metafields.custom.angle_3_title != blank %}\n  <div class=\"angle-box\">\n    <div class=\"angle-img\">\n      {% if product.metafields.custom.angle_3_image != blank %}\n        <img src=\"{{ product.metafields.custom.angle_3_image | image_url: width: 600 }}\" alt=\"{{ product.metafields.custom.angle_3_title }}\">\n      {% else %}\n        <img src=\"https://via.placeholder.com/600x450?text=No+Image\" alt=\"No image\">\n      {% endif %}\n    </div>\n    <h3 class=\"angle-title\">{{ product.metafields.custom.angle_3_title }}</h3>\n    {% if product.metafields.custom.angle_3_text != blank %}\n      <p class=\"angle-desc\">{{ product.metafields.custom.angle_3_text }}</p>\n    {% endif %}\n  </div>\n  {% endif %}\n  \n</section>\n{% endif %}\n\n<style>\n.product-angles {\n  font-family: 'Inter', sans-serif;\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 30px;\n  width: 100%;\n  padding: 40px 0;\n}\n.angle-box {\n  text-align: center;\n}\n.angle-img {\n  width: 100%;\n  aspect-ratio: 1/1;\n  border-radius: 10px;\n  overflow: hidden;\n  margin-bottom: 20px;\n}\n.angle-img img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.3s;\n}\n.angle-box:hover .angle-img img {\n  transform: scale(1.05);\n}\n.angle-title {\n  font-size: 18px;\n  font-weight: 700;\n  color: #041626;\n  margin: 0 0 10px 0;\n}\n.angle-desc {\n  font-size: 14px;\n  font-weight: 400;\n  color: #555;\n  line-height: 1.6;\n  margin: 0;\n}\n@media (max-width: 768px) {\n  .product-angles {\n    grid-template-columns: 1fr;\n    gap: 60px;\n    padding: 30px 0;\n  }\n  \n  .angle-img {\n    aspect-ratio: 1/1;\n  }\n  \n  .angle-title {\n    font-size: 20px;\n  }\n  \n  .angle-desc {\n    font-size: 15px;\n    max-width: 400px;\n    margin: 0 auto;\n  }\n}\n</style>"

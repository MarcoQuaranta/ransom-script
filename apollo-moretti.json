 var cardWidth = card.offsetWidth + gap;\n    carousel.scrollBy({\n      left: direction * cardWidth * cardsPerView,\n      behavior: 'smooth'\n    });\n  };\n  \n  var autoScroll = setInterval(function() {\n    var maxScroll = carousel.scrollWidth - carousel.clientWidth;\n    if (carousel.scrollLeft >= maxScroll - 10) {\n      carousel.scrollTo({ left: 0, behavior: 'smooth' });\n    } else {\n      var card = carousel.querySelector('.itlv-card');\n      var style = window.getComputedStyle(carousel);\n      var gap = parseInt(style.gap) || 20;\n      var cardWidth = card.offsetWidth + gap;\n      carousel.scrollBy({ left: cardWidth * cardsPerView, behavior: 'smooth' });\n    }\n  }, 5000);\n  \n  carousel.addEventListener('mouseenter', function() { clearInterval(autoScroll); });\n  carousel.addEventListener('mouseleave', function() {\n    autoScroll = setInterval(function() {\n      var maxScroll = carousel.scrollWidth - carousel.clientWidth;\n      if (carousel.scrollLeft >= maxScroll - 10) {\n        carousel.scrollTo({ left: 0, behavior: 'smooth' });\n      } else {\n        var card = carousel.querySelector('.itlv-card');\n        var style = window.getComputedStyle(carousel);\n        var gap = parseInt(style.gap) || 20;\n        var cardWidth = card.offsetWidth + gap;\n        carousel.scrollBy({ left: cardWidth * cardsPerView, behavior: 'smooth' });\n      }\n    }, 5000);\n  });\n  \n  var touchStartX = 0;\n  carousel.addEventListener('touchstart', function(e) {\n    touchStartX = e.changedTouches[0].screenX;\n  }, { passive: true });\n  \n  carousel.addEventListener('touchend', function(e) {\n    var diff = touchStartX - e.changedTouches[0].screenX;\n    if (Math.abs(diff) > 50) itlvScroll(diff > 0 ? 1 : -1);\n  }, { passive: true });\n})();\n</script>",

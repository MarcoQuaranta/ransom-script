    "custom_liquid_bney9n": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<section class=\"faq-section\">\n  <div class=\"faq-box\">\n    <div class=\"faq-container\">\n      \n      <div class=\"faq-left\">\n        <h2 class=\"faq-title\">FAQ</h2>\n        <p class=\"faq-intro\">Still have questions? If you can't find what you're looking for, we're here to help. Reach out to us at:</p>\n        <a href=\"mailto:info@italivio.com\" class=\"faq-email\">info@italivio.com</a>\n        <p class=\"faq-hours\">Our team is available Monday through Saturday, 9:00 a.m. to 8:00 p.m. EST. Drop us a line anytime and we'll get back to you as soon as possible.</p>\n        <p class=\"faq-response\">Average response time: 24 hours.</p>\n      </div>\n      \n      <div class=\"faq-right\">\n        <div class=\"faq-accordion\">\n          \n          <div class=\"faq-item active\">\n            <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n              <span>Is my payment secure?</span>\n              <span class=\"faq-icon\"></span>\n            </button>\n            <div class=\"faq-answer\">\n              <p>Absolutely. We use industry-leading encryption and secure payment processing to keep your information safe.</p>\n            </div>\n          </div>\n          \n          <div class=\"faq-item\">\n            <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n              <span>Is shipping free?</span>\n              <span class=\"faq-icon\"></span>\n            </button>\n            <div class=\"faq-answer\">\n              <p>Yes! We offer free shipping on all orders.</p>\n            </div>\n          </div>\n          \n          <div class=\"faq-item\">\n            <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n              <span>What if I change my mind?</span>\n              <span class=\"faq-icon\"></span>\n            </button>\n            <div class=\"faq-answer\">\n              <p>No worries. You have 30 days to return any unworn item for a full refund. Just reach out to our team to start the process.</p>\n            </div>\n          </div>\n          \n          <div class=\"faq-item\">\n            <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n              <span>What if my size is out of stock?</span>\n              <span class=\"faq-icon\"></span>\n            </button>\n            <div class=\"faq-answer\">\n              <p>Sign up for restock alerts on the product page. We'll notify you the moment your size is back.</p>\n            </div>\n          </div>\n          \n          <div class=\"faq-item\">\n            <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n              <span>Need help with your order?</span>\n              <span class=\"faq-icon\"></span>\n            </button>\n            <div class=\"faq-answer\">\n              <p>Email us at info@italivio.com with your order number. We'll sort it out fast.</p>\n            </div>\n          </div>\n          \n        </div>\n      </div>\n      \n    </div>\n  </div>\n</section>\n\n<style>\n.faq-section {\n  font-family: 'Inter', sans-serif;\n  padding: 40px 20px;\n  width: 100%;\n  box-sizing: border-box;\n}\n\n.faq-box {\n  background: #fff;\n  border-radius: 16px;\n  box-shadow: 0 4px 30px rgba(0,0,0,0.08);\n  padding: 50px;\n  max-width: 1100px;\n  margin: 0 auto;\n}\n\n.faq-container {\n  display: flex;\n  gap: 60px;\n  align-items: flex-start;\n}\n\n.faq-left {\n  flex: 1;\n  max-width: 400px;\n}\n\n.faq-title {\n  font-family: 'Inter', sans-serif;\n  font-size: 42px;\n  font-weight: 700;\n  color: #092C4E;\n  margin: 0 0 25px 0;\n}\n\n.faq-intro {\n  font-size: 14px;\n  color: #333;\n  line-height: 1.7;\n  margin: 0 0 15px 0;\n}\n\n.faq-email {\n  display: inline-block;\n  font-size: 14px;\n  color: #092C4E;\n  text-decoration: underline;\n  margin-bottom: 25px;\n}\n\n.faq-email:hover {\n  opacity: 0.7;\n}\n\n.faq-hours {\n  font-size: 14px;\n  color: #333;\n  line-height: 1.7;\n  margin: 0 0 10px 0;\n}\n\n.faq-response {\n  font-size: 14px;\n  color: #666;\n  margin: 0;\n}\n\n.faq-right {\n  flex: 1;\n  max-width: 520px;\n}\n\n.faq-accordion {\n  background: #092C4E;\n  border-radius: 12px;\n  overflow: hidden;\n}\n\n.faq-item {\n  border-bottom: 1px solid rgba(255,255,255,0.1);\n}\n\n.faq-item:last-child {\n  border-bottom: none;\n}\n\n.faq-question {\n  width: 100%;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 20px 25px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  text-align: left;\n}\n\n.faq-question span:first-child {\n  font-family: 'Inter', sans-serif;\n  font-size: 15px;\n  font-weight: 600;\n  color: #fff;\n  flex: 1;\n  padding-right: 15px;\n}\n\n.faq-icon {\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  background: rgba(255,255,255,0.15);\n  position: relative;\n  flex-shrink: 0;\n  transition: background 0.3s;\n}\n\n.faq-icon::before,\n.faq-icon::after {\n  content: '';\n  position: absolute;\n  background: #fff;\n  transition: transform 0.3s;\n}\n\n.faq-icon::before {\n  width: 12px;\n  height: 2px;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.faq-icon::after {\n  width: 2px;\n  height: 12px;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.faq-item.active .faq-icon::after {\n  transform: translate(-50%, -50%) rotate(90deg);\n}\n\n.faq-item.active .faq-icon {\n  background: rgba(255,255,255,0.25);\n}\n\n.faq-answer {\n  max-height: 0;\n  overflow: hidden;\n  transition: max-height 0.3s ease;\n}\n\n.faq-item.active .faq-answer {\n  max-height: 200px;\n}\n\n.faq-answer p {\n  margin: 0;\n  padding: 0 25px 20px 25px;\n  font-size: 14px;\n  color: rgba(255,255,255,0.85);\n  line-height: 1.7;\n}\n\n@media (max-width: 900px) {\n  .faq-section {\n    padding: 30px 10px;\n  }\n  \n  .faq-box {\n    padding: 35px 20px;\n  }\n  \n  .faq-container {\n    flex-direction: column;\n    gap: 35px;\n  }\n  \n  .faq-left,\n  .faq-right {\n    max-width: 100%;\n    width: 100%;\n  }\n  \n  .faq-title {\n    font-size: 32px;\n  }\n}\n\n@media (max-width: 500px) {\n  .faq-section {\n    padding: 25px 5px;\n  }\n  \n  .faq-box {\n    padding: 25px 15px;\n  }\n  \n  .faq-title {\n    font-size: 28px;\n  }\n  \n  .faq-question {\n    padding: 18px 18px;\n  }\n  \n  .faq-question span:first-child {\n    font-size: 14px;\n  }\n  \n  .faq-answer p {\n    padding: 0 18px 18px 18px;\n    font-size: 13px;\n  }\n  \n  .faq-icon {\n    width: 24px;\n    height: 24px;\n  }\n  \n  .faq-icon::before {\n    width: 10px;\n  }\n  \n  .faq-icon::after {\n    height: 10px;\n  }\n}\n</style>\n\n<script>\nfunction toggleFaq(btn) {\n  var item = btn.parentElement;\n  var isActive = item.classList.contains('active');\n  \n  document.querySelectorAll('.faq-item').forEach(function(el) {\n    el.classList.remove('active');\n  });\n  \n  if (!isActive) {\n    item.classList.add('active');\n  }\n}\n</script>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },

            "custom_liquid_8fEwNT": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<!-- ITALIVIO Badges - Tema Outsiders/Rebels -->\n<!-- Con Badge Sconto Diagonale Dinamico -->\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n{% comment %} Calcolo sconto dinamico Shopify {% endcomment %}\n{% assign has_discount = false %}\n{% assign discount_percentage = 0 %}\n\n{% if product.compare_at_price > product.price %}\n  {% assign has_discount = true %}\n  {% assign discount = product.compare_at_price | minus: product.price %}\n  {% assign discount_percentage = discount | times: 100.0 | divided_by: product.compare_at_price | round %}\n{% endif %}\n\n<style>\n  slideshow-container {\n    position: relative !important;\n  }\n\n  .italivio-badge,\n  .italivio-viewers {\n    position: absolute;\n    z-index: 999;\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    padding: 10px 16px;\n    border-radius: 8px;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    font-weight: 500;\n    font-size: 13px;\n    line-height: 1;\n    letter-spacing: -0.01em;\n    backdrop-filter: blur(10px);\n    -webkit-backdrop-filter: blur(10px);\n    white-space: nowrap;\n    pointer-events: none;\n    opacity: 0;\n    transform: translateY(8px);\n    transition: opacity 0.4s ease, transform 0.4s ease;\n  }\n  \n  .italivio-badge.is-visible,\n  .italivio-viewers.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .italivio-badge {\n    left: 16px;\n    bottom: 16px;\n    background: rgba(249, 115, 22, 0.7);\n    color: #ffffff;\n    box-shadow: 0 2px 12px rgba(249, 115, 22, 0.3);\n  }\n  \n  .italivio-badge::before {\n    content: '';\n    width: 8px;\n    height: 8px;\n    background: #ffffff;\n    border-radius: 50%;\n    flex-shrink: 0;\n    animation: italivio-pulse 2s ease-in-out infinite;\n  }\n\n  .italivio-viewers {\n    right: 16px;\n    top: 16px;\n    background: rgba(255, 255, 255, 0.4);\n    color: #0a1628;\n    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);\n  }\n  \n  .italivio-viewers .dot {\n    width: 8px;\n    height: 8px;\n    background: #22c55e;\n    border-radius: 50%;\n    flex-shrink: 0;\n    animation: italivio-pulse 2s ease-in-out infinite;\n  }\n  \n  .italivio-viewers .num {\n    font-weight: 600;\n    color: #0a1628;\n  }\n\n  .italivio-discount-ribbon {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 120px;\n    height: 120px;\n    overflow: hidden;\n    z-index: 1000;\n    pointer-events: none;\n  }\n\n  .italivio-discount-ribbon__inner {\n    position: absolute;\n    top: 22px;\n    left: -32px;\n    width: 140px;\n    height: 32px;\n    background: linear-gradient(135deg, #ef4444 0%, #dc2626 50%, #b91c1c 100%);\n    transform: rotate(-45deg);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: \n      0 4px 15px rgba(220, 38, 38, 0.4),\n      0 2px 4px rgba(0, 0, 0, 0.2);\n    opacity: 0;\n    transition: opacity 0.5s ease 0.2s;\n  }\n\n  .italivio-discount-ribbon__inner.is-visible {\n    opacity: 1;\n  }\n\n  .italivio-discount-ribbon__text {\n    color: #ffffff;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);\n  }\n\n  @keyframes italivio-pulse {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50% { opacity: 0.6; transform: scale(0.85); }\n  }\n\n  @media (max-width: 749px) {\n    .italivio-badge,\n    .italivio-viewers {\n      padding: 8px 12px;\n      font-size: 12px;\n      gap: 6px;\n    }\n    .italivio-badge {\n      left: 12px;\n      bottom: 12px;\n    }\n    .italivio-viewers {\n      right: 12px;\n      top: 12px;\n    }\n    .italivio-badge::before,\n    .italivio-viewers .dot {\n      width: 6px;\n      height: 6px;\n    }\n    .italivio-discount-ribbon {\n      width: 100px;\n      height: 100px;\n    }\n    .italivio-discount-ribbon__inner {\n      top: 18px;\n      left: -28px;\n      width: 120px;\n      height: 26px;\n    }\n    .italivio-discount-ribbon__text {\n      font-size: 11px;\n    }\n  }\n</style>\n\n<script>\n(function() {\n  if (window.__italivio_badge_init) return;\n  window.__italivio_badge_init = true;\n\n  // ========================================\n  // VIEWERS: numero base unico per prodotto\n  // ========================================\n  var productId = {{ product.id | json }};\n  \n  function generateBaseFromProductId(id) {\n    var hash = 0;\n    var idStr = String(id);\n    for (var i = 0; i < idStr.length; i++) {\n      hash = ((hash << 5) - hash) + idStr.charCodeAt(i);\n      hash = hash & hash;\n    }\n    return Math.abs(hash % 81) + 15; // Range 15-95\n  }\n\n  var baseViewers = generateBaseFromProductId(productId);\n  var currentViewers = baseViewers;\n  var oscillationRange = 4;\n\n  var msgIndex = 0;\n  var badge1, badge2, discountRibbon;\n  var messageInterval = null;\n  var viewerInterval = null;\n\n  var hasDiscount = {{ has_discount | json }};\n  var discountPercentage = {{ discount_percentage | json }};\n\n  var messages = [\n    \"High demand today\",\n    \"Limited availability\",\n    \"20+ sold in 24h\",\n    \"Selling fast\",\n    \"Few items left\"\n  ];\n\n  // Oscillazione viewers - ogni 3 secondi\n  function startViewerOscillation() {\n    // Pulisci interval esistente\n    if (viewerInterval) {\n      clearInterval(viewerInterval);\n      viewerInterval = null;\n    }\n    \n    viewerInterval = setInterval(function() {\n      var offset = Math.floor(Math.random() * (oscillationRange * 2 + 1)) - oscillationRange;\n      currentViewers = baseViewers + offset;\n      currentViewers = Math.max(15, Math.min(95, currentViewers));\n      \n      var numEl = document.querySelector('.italivio-viewers .num');\n      if (numEl) numEl.textContent = currentViewers;\n    }, 3000);\n  }\n\n  // Rimuove badge esistenti\n  function removeBadges() {\n    document.querySelectorAll('.italivio-badge, .italivio-viewers, .italivio-discount-ribbon').forEach(function(el) {\n      el.remove();\n    });\n    if (messageInterval) {\n      clearInterval(messageInterval);\n      messageInterval = null;\n    }\n  }\n\n  function mount() {\n    var container = document.querySelector('slideshow-container');\n    if (!container) return false;\n\n    removeBadges();\n\n    // Badge sconto\n    if (hasDiscount && discountPercentage > 0) {\n      discountRibbon = document.createElement('div');\n      discountRibbon.className = 'italivio-discount-ribbon';\n      discountRibbon.innerHTML = \n        '<div class=\"italivio-discount-ribbon__inner\">' +\n          '<span class=\"italivio-discount-ribbon__text\">-' + discountPercentage + '%</span>' +\n        '</div>';\n      container.appendChild(discountRibbon);\n\n      setTimeout(function() {\n        var inner = discountRibbon.querySelector('.italivio-discount-ribbon__inner');\n        if (inner) inner.classList.add('is-visible');\n      }, 100);\n    }\n\n    // Badge basso sinistra\n    badge1 = document.createElement('div');\n    badge1.className = 'italivio-badge';\n    badge1.innerHTML = messages[msgIndex];\n\n    // Badge alto destra\n    badge2 = document.createElement('div');\n    badge2.className = 'italivio-viewers';\n    badge2.innerHTML = '<span class=\"dot\"></span><span class=\"num\">' + currentViewers + '</span> people viewing';\n\n    container.appendChild(badge1);\n    container.appendChild(badge2);\n\n    setTimeout(function() {\n      badge1.classList.add('is-visible');\n      badge2.classList.add('is-visible');\n    }, 100);\n\n    // Rotazione messaggi\n    messageInterval = setInterval(function() {\n      msgIndex = (msgIndex + 1) % messages.length;\n      if (badge1) {\n        badge1.style.opacity = '0';\n        setTimeout(function() {\n          if (badge1) {\n            badge1.innerHTML = messages[msgIndex];\n            badge1.style.opacity = '1';\n          }\n        }, 200);\n      }\n    }, 4000);\n\n    return true;\n  }\n\n  function init() {\n    var attempts = 0;\n    function tryMount() {\n      attempts++;\n      if (mount()) {\n        startViewerOscillation();\n        return;\n      }\n      if (attempts < 30) setTimeout(tryMount, 200);\n    }\n    tryMount();\n  }\n\n  // ========================================\n  // Listener per cambio variante\n  // ========================================\n  \n  function setupObserver() {\n    var container = document.querySelector('slideshow-container');\n    if (!container) return;\n\n    var observer = new MutationObserver(function(mutations) {\n      if (!document.querySelector('.italivio-badge')) {\n        setTimeout(mount, 100);\n      }\n    });\n\n    observer.observe(container, { \n      childList: true, \n      subtree: true \n    });\n  }\n\n  document.addEventListener('variant:change', function() {\n    setTimeout(mount, 300);\n  });\n\n  document.addEventListener('shopify:section:load', function() {\n    setTimeout(init, 300);\n  });\n\n  document.addEventListener('click', function(e) {\n    var target = e.target;\n    if (target.closest('.product-form__input') || \n        target.closest('[data-variant-input]') ||\n        target.closest('.variant-input') ||\n        target.closest('.swatch') ||\n        target.closest('[data-option-selector]') ||\n        target.closest('.product__option')) {\n      setTimeout(function() {\n        if (!document.querySelector('.italivio-badge')) {\n          mount();\n        }\n      }, 500);\n    }\n  });\n\n  document.addEventListener('change', function(e) {\n    var target = e.target;\n    if (target.closest('[name^=\"options\"]') || \n        target.closest('select[name=\"id\"]') ||\n        target.closest('.product-form') ||\n        target.closest('[data-product-form]')) {\n      setTimeout(function() {\n        if (!document.querySelector('.italivio-badge')) {\n          mount();\n        }\n      }, 500);\n    }\n  });\n\n  setInterval(function() {\n    var container = document.querySelector('slideshow-container');\n    if (container && !document.querySelector('.italivio-badge')) {\n      mount();\n    }\n  }, 2000);\n\n  // Init\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', function() { \n      setTimeout(init, 300);\n      setTimeout(setupObserver, 500);\n    });\n  } else {\n    setTimeout(init, 300);\n    setTimeout(setupObserver, 500);\n  }\n  \n  window.addEventListener('load', function() { \n    setTimeout(init, 500);\n    setTimeout(setupObserver, 700);\n  });\n\n})();\n</script>"

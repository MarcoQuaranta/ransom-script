    "custom_liquid_yNLw87": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n.itlv-reviews-section {\n  max-width: 1200px !important;\n  width: 100% !important;\n  margin: 0 auto !important;\n  padding: 60px 20px !important;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;\n  background: #fff !important;\n  box-sizing: border-box !important;\n}\n\n.itlv-reviews-section * {\n  box-sizing: border-box !important;\n}\n\n.itlv-reviews-header {\n  text-align: center !important;\n  margin-bottom: 40px !important;\n}\n\n.itlv-reviews-header h2 {\n  font-size: 32px !important;\n  font-weight: 700 !important;\n  color: #1a1a1a !important;\n  margin: 0 0 16px 0 !important;\n  padding: 0 !important;\n}\n\n.itlv-rating-summary {\n  display: flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n  gap: 8px !important;\n  margin-bottom: 8px !important;\n}\n\n.itlv-rating-text {\n  font-size: 18px !important;\n  font-weight: 600 !important;\n  color: #1a1a1a !important;\n}\n\n.itlv-stars-summary {\n  display: flex !important;\n  gap: 2px !important;\n}\n\n.itlv-stars-summary .itlv-star {\n  width: 24px !important;\n  height: 24px !important;\n  background: #00b67a !important;\n  display: flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n}\n\n.itlv-stars-summary .itlv-star svg {\n  width: 14px !important;\n  height: 14px !important;\n  fill: #fff !important;\n}\n\n.itlv-reviews-count {\n  font-size: 14px !important;\n  color: #666 !important;\n}\n\n.itlv-reviews-count span {\n  text-decoration: underline !important;\n  font-weight: 500 !important;\n}\n\n.itlv-carousel-wrapper {\n  position: relative !important;\n  padding: 0 60px !important;\n}\n\n.itlv-carousel {\n  display: grid !important;\n  grid-auto-flow: column !important;\n  grid-auto-columns: calc((100% - 40px) / 3) !important;\n  gap: 20px !important;\n  overflow-x: auto !important;\n  scroll-behavior: smooth !important;\n  
            "custom_liquid_zATMEf": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<div class=\"shipping-bar\">\n  <div class=\"shipping-left\">\n    <span class=\"shipping-dot\"></span>\n    <span class=\"shipping-text\">Arrives by <strong id=\"deliveryDate\"></strong></span>\n  </div>\n  <div class=\"shipping-right\">\n    <span class=\"shipping-free\">US <strong>Free</strong> Shipping</span>\n  </div>\n</div>\n<style>\n.shipping-bar {\n  font-family: 'Inter', sans-serif;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 14px 18px;\n  background: #f8f8f8;\n  border-radius: 6px;\n  margin: 0px 0;\n}\n.shipping-left {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n.shipping-dot {\n  width: 10px;\n  height: 10px;\n  background: #22c55e;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n.shipping-text {\n  font-size: 14px;\n  color: #041626;\n}\n.shipping-text strong {\n  font-weight: 600;\n  color: #166534;\n}\n.shipping-right {\n  font-size: 14px;\n  color: #041626;\n}\n.shipping-free strong {\n  font-weight: 600;\n}\n@media (max-width: 500px) {\n  .shipping-bar {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 8px;\n    padding: 12px 15px;\n  }\n  \n  .shipping-text,\n  .shipping-free {\n    font-size: 13px;\n  }\n}\n</style>\n<script>\n(function() {\n  var options = { month: 'short', day: 'numeric' };\n  \n  var minDate = new Date();\n  minDate.setDate(minDate.getDate() + 3);\n  \n  var maxDate = new Date();\n  maxDate.setDate(maxDate.getDate() + 10);\n  \n  var minStr = minDate.toLocaleDateString('en-US', options);\n  var maxStr = maxDate.toLocaleDateString('en-US', options);\n  \n  document.getElementById('deliveryDate').textContent = minStr + ' - ' + maxStr;\n})();\n</script>"

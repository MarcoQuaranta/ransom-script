            "custom_liquid_NyUC8f": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<button class=\"size-guide-btn\" onclick=\"openSizeGuide()\">\n  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 3H3v7h18V3z\"/><path d=\"M21 14h-5v7h5v-7z\"/><path d=\"M12 14H3v7h9v-7z\"/></svg>\n  Size Guide\n</button>\n\n<div class=\"size-modal-overlay\" id=\"sizeModal\" style=\"display:none\" onclick=\"closeSizeGuide(event)\">\n  <div class=\"size-modal\">\n    <button class=\"size-modal-close\" onclick=\"closeSizeGuide()\">&times;</button>\n    {{ product.metafields.custom.size_guide2.value }}\n  </div>\n</div>\n\n<style>\n.size-guide-btn {\n  font-family: 'Inter', sans-serif;\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 0;\n  background: none;\n  color: #041626;\n  border: none;\n  font-size: 14px;\n  font-weight: 500;\n  cursor: pointer;\n}\n\n.size-guide-btn:hover {\n  opacity: 0.7;\n}\n\n.size-modal-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(0,0,0,0.6);\n  z-index: 2147483646 !important;\n  align-items: center;\n  justify-content: center;\n  padding: 20px;\n}\n\n.size-modal-overlay.active {\n  display: flex !important;\n}\n\n.size-modal {\n  font-family: 'Inter', sans-serif;\n  background: #fff;\n  border-radius: 12px;\n  width: 100%;\n  max-width: 600px;\n  max-height: 85vh;\n  overflow-y: auto;\n  position: relative;\n  padding: 30px;\n  z-index: 2147483647 !important;\n}\n\n.size-modal-close {\n  position: absolute;\n  top: 15px;\n  right: 15px;\n  background: none;\n  border: none;\n  font-size: 28px;\n  color: #666;\n  cursor: pointer;\n  line-height: 1;\n}\n\n.size-modal-close:hover {\n  color: #000;\n}\n\n.size-modal-title {\n  font-size: 22px;\n  font-weight: 700;\n  color: #041626;\n  margin: 0 0 20px 0;\n}\n\n.size-tabs {\n  display: flex;\n  gap: 10px;\n  margin-bottom: 25px;\n}\n\n.size-tab {\n  flex: 1;\n  padding: 12px;\n  background: #f0f0f0;\n  border: none;\n  border-radius: 6px;\n  font-family: 'Inter', sans-serif;\n  font-size: 14px;\n  font-weight: 600;\n  color: #666;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.size-tab.active {\n  background: #041626;\n  color: #fff;\n}\n\n.size-section {\n  margin-bottom: 25px;\n}\n\n.size-section-title {\n  font-size: 16px;\n  font-weight: 600;\n  color: #041626;\n  margin: 0 0 12px 0;\n}\n\n.size-table-wrap {\n  overflow-x: auto;\n}\n\n.size-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: 13px;\n}\n\n.size-table th,\n.size-table td {\n  padding: 10px 12px;\n  text-align: center;\n  border: 1px solid #e0e0e0;\n}\n\n.size-table th {\n  background: #f5f5f5;\n  font-weight: 600;\n  color: #041626;\n}\n\n.size-table td {\n  color: #333;\n}\n\n.size-table tr:nth-child(even) td {\n  background: #fafafa;\n}\n\n.size-note {\n  font-size: 12px;\n  color: #888;\n  margin: 20px 0 0 0;\n  text-align: center;\n}\n\n@media (max-width: 480px) {\n  .size-modal {\n    padding: 20px;\n  }\n  \n  .size-modal-title {\n    font-size: 18px;\n  }\n  \n  .size-table {\n    font-size: 12px;\n  }\n  \n  .size-table th,\n  .size-table td {\n    padding: 8px 6px;\n  }\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  var modal = document.getElementById('sizeModal');\n  document.body.appendChild(modal);\n});\n\nfunction openSizeGuide() {\n  var modal = document.getElementById('sizeModal');\n  modal.style.display = 'flex';\n  modal.classList.add('active');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeSizeGuide(e) {\n  if (!e || e.target === e.currentTarget) {\n    var modal = document.getElementById('sizeModal');\n    modal.style.display = 'none';\n    modal.classList.remove('active');\n    document.body.style.overflow = '';\n  }\n}\n\nfunction switchTab(tab) {\n  document.querySelectorAll('.size-tab').forEach(function(t) {\n    t.classList.remove('active');\n  });\n  event.target.classList.add('active');\n  \n  document.querySelectorAll('.size-content').forEach(function(c) {\n    c.style.display = 'none';\n  });\n  document.getElementById(tab).style.display = 'block';\n}\n</script>"

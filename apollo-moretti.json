              "settings": {
                "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n\n{% if product.metafields.custom.bullet_1 != blank or product.metafields.custom.bullet_2 != blank or product.metafields.custom.bullet_3 != blank %}\n<div class=\"product-bullets\">\n  {% if product.metafields.custom.bullet_1 != blank %}\n  <div class=\"product-bullet\">\n    <span class=\"bullet-dot\"></span>\n    <span class=\"bullet-text\">{{ product.metafields.custom.bullet_1 }}</span>\n  </div>\n  {% endif %}\n  {% if product.metafields.custom.bullet_2 != blank %}\n  <div class=\"product-bullet\">\n    <span class=\"bullet-dot\"></span>\n    <span class=\"bullet-text\">{{ product.metafields.custom.bullet_2 }}</span>\n  </div>\n  {% endif %}\n  {% if product.metafields.custom.bullet_3 != blank %}\n  <div class=\"product-bullet\">\n    <span class=\"bullet-dot\"></span>\n    <span class=\"bullet-text\">{{ product.metafields.custom.bullet_3 }}</span>\n  </div>\n  {% endif %}\n</div>\n{% endif %}\n\n<style>\n.product-bullets {\n  font-family: 'Inter', sans-serif;\n  margin: 10px 0;\n}\n\n.product-bullet {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 5px 0;\n}\n\n.bullet-dot {\n  width: 8px;\n  height: 8px;\n  background: #041626;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n.bullet-text {\n  font-size: 16px;\n  font-weight: 500;\n  \n  line-height: 1.4;\n}\n</style>"

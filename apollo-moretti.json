        "custom_liquid_xiibdU": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n{% if product.metafields.custom.lifestyle_main_title != blank %}\n<section class=\"lifestyle-section\">\n  \n  <h2 class=\"lifestyle-main-title\">{{ product.metafields.custom.lifestyle_main_title }}</h2>\n  \n  <div class=\"lifestyle-grid\">\n    \n    {% if product.metafields.custom.lifestyle_left_title != blank %}\n    <div class=\"lifestyle-text lifestyle-text--left\">\n      <div class=\"lifestyle-icon\">\n        {% if product.metafields.custom.lifestyle_left_icon != blank %}\n          <img src=\"{{ product.metafields.custom.lifestyle_left_icon | image_url: width: 64 }}\" alt=\"\" width=\"32\" height=\"32\">\n        {% else %}\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>\n        {% endif %}\n      </div>\n      <h3 class=\"lifestyle-title\">{{ product.metafields.custom.lifestyle_left_title }}</h3>\n      {% if product.metafields.custom.lifestyle_left_text != blank %}\n        <p class=\"lifestyle-desc\">{{ product.metafields.custom.lifestyle_left_text }}</p>\n      {% endif %}\n    </div>\n    {% endif %}\n    \n    <div class=\"lifestyle-gif\">\n      {% if product.metafields.custom.lifestyle_image != blank %}\n        <img src=\"{{ product.metafields.custom.lifestyle_image | image_url: width: 900 }}\" alt=\"{{ product.metafields.custom.lifestyle_main_title }}\">\n      {% else %}\n        <img src=\"https://via.placeholder.com/450x450?text=No+Image\" alt=\"No image\">\n      {% endif %}\n    </div>\n    \n    {% if product.metafields.custom.lifestyle_right_title != blank %}\n    <div class=\"lifestyle-text lifestyle-text--right\">\n      <div class=\"lifestyle-icon\">\n        {% if product.metafields.custom.lifestyle_right_icon != blank %}\n          <img src=\"{{ product.metafields.custom.lifestyle_right_icon | image_url: width: 64 }}\" alt=\"\" width=\"32\" height=\"32\">\n        {% else %}\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"></polyline></svg>\n        {% endif %}\n      </div>\n      <h3 class=\"lifestyle-title\">{{ product.metafields.custom.lifestyle_right_title }}</h3>\n      {% if product.metafields.custom.lifestyle_right_text != blank %}\n        <p class=\"lifestyle-desc\">{{ product.metafields.custom.lifestyle_right_text }}</p>\n      {% endif %}\n    </div>\n    {% endif %}\n    \n  </div>\n  \n</section>\n{% endif %}\n\n<style>\n.lifestyle-section {\n  font-family: 'Inter', sans-serif;\n  padding: 50px 0px;\n  width: 100%;\n  box-sizing: border-box;\n}\n.lifestyle-main-title {\n  font-size: 32px;\n  font-weight: 700;\n  color: #041626;\n  text-align: center;\n  margin: 0 0 40px 0;\n}\n.lifestyle-grid {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  width: 100%;\n  gap: 40px;\n}\n.lifestyle-text {\n  flex: 1;\n}\n.lifestyle-text--left {\n  text-align: right;\n}\n.lifestyle-text--right {\n  text-align: left;\n}\n.lifestyle-title {\n  font-size: 20px;\n  font-weight: 700;\n  color: #041626;\n  margin: 0 0 12px 0;\n}\n.lifestyle-icon {\n  color: #041626;\n  margin-bottom: 16px;\n}\n.lifestyle-icon img {\n  width: 32px;\n  height: 32px;\n  object-fit: contain;\n}\n.lifestyle-text--left .lifestyle-icon {\n  display: flex;\n  justify-content: flex-end;\n}\n.lifestyle-text--right .lifestyle-icon {\n  display: flex;\n  justify-content: flex-start;\n}\n.lifestyle-desc {\n  font-size: 15px;\n  font-weight: 400;\n  color: #041626;\n  line-height: 1.6;\n  margin: 0;\n  opacity: 0.8;\n}\n.lifestyle-gif {\n  width: 450px;\n  height: 450px;\n  border-radius: 12px;\n  overflow: hidden;\n  flex-shrink: 0;\n}\n.lifestyle-gif img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n@media (max-width: 900px) {\n  .lifestyle-section {\n    padding: 40px 0px;\n  }\n  \n  .lifestyle-main-title {\n    font-size: 26px;\n    margin-bottom: 30px;\n  }\n  \n  .lifestyle-grid {\n    flex-direction: column;\n    gap: 50px;\n  }\n  \n  .lifestyle-text {\n    text-align: center;\n    width: 100%;\n  }\n  \n  .lifestyle-text--left,\n  .lifestyle-text--right {\n    text-align: center;\n  }\n  \n  .lifestyle-text--left .lifestyle-icon,\n  .lifestyle-text--right .lifestyle-icon {\n    justify-content: center;\n  }\n  \n  .lifestyle-text--left {\n    order: 1;\n  }\n  \n  .lifestyle-gif {\n    order: 2;\n    width: 100%;\n    height: auto;\n    aspect-ratio: 1;\n  }\n  \n  .lifestyle-text--right {\n    order: 3;\n  }\n}\n</style>"

            "custom_liquid_N7D3m9": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n\n<div class=\"trust-accordion\">\n  \n  <div class=\"trust-item\">\n    <button class=\"trust-header\" onclick=\"toggleAccordion(this)\">\n      <span class=\"trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg>\n      </span>\n      <span class=\"trust-title\">Secure Payment</span>\n      <span class=\"trust-arrow\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </span>\n    </button>\n    <div class=\"trust-content\">\n      <p>All transactions are encrypted with SSL technology. We accept Visa, Mastercard, American Express, PayPal, and Apple Pay. Your data is never stored on our servers.</p>\n    </div>\n  </div>\n  \n  <div class=\"trust-item\">\n    <button class=\"trust-header\" onclick=\"toggleAccordion(this)\">\n      <span class=\"trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path><polyline points=\"9 12 11 14 15 10\"></polyline></svg>\n      </span>\n      <span class=\"trust-title\">Insured Shipping</span>\n      <span class=\"trust-arrow\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </span>\n    </button>\n    <div class=\"trust-content\">\n      <p>Every order is fully insured during transit. If your package is lost or damaged, we'll send a replacement at no extra cost. Tracking included on all orders.</p>\n    </div>\n  </div>\n  \n  <div class=\"trust-item\">\n    <button class=\"trust-header\" onclick=\"toggleAccordion(this)\">\n      <span class=\"trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"1 4 1 10 7 10\"></polyline><path d=\"M3.51 15a9 9 0 1 0 2.13-9.36L1 10\"></path></svg>\n      </span>\n      <span class=\"trust-title\">30-Day Returns</span>\n      <span class=\"trust-arrow\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </span>\n    </button>\n    <div class=\"trust-content\">\n      <p>Not satisfied? Return any unworn item within 30 days for a full refund. No questions asked. We'll even cover return shipping on orders over $50.</p>\n    </div>\n  </div>\n  \n</div>\n\n<style>\n.trust-accordion {\n  font-family: 'Inter', sans-serif;\n  margin: 25px 0;\n  background: #092C4E;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.trust-item {\n  border-bottom: 1px solid rgba(255,255,255,0.12);\n}\n\n.trust-item:last-child {\n  border-bottom: none;\n}\n\n.trust-header {\n  width: 100%;\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  padding: 18px 20px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  text-align: left;\n  transition: background 0.2s;\n}\n\n.trust-header:hover {\n  background: rgba(255,255,255,0.05);\n}\n\n.trust-icon {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 36px;\n  height: 36px;\n  background: rgba(255,255,255,0.1);\n  border-radius: 50%;\n  color: #fff;\n  flex-shrink: 0;\n}\n\n.trust-title {\n  flex: 1;\n  font-size: 15px;\n  font-weight: 600;\n  color: #fff;\n  letter-spacing: -0.01em;\n}\n\n.trust-arrow {\n  color: rgba(255,255,255,0.6);\n  transition: transform 0.3s;\n  display: flex;\n  align-items: center;\n}\n\n.trust-item.active .trust-arrow {\n  transform: rotate(180deg);\n}\n\n.trust-content {\n  max-height: 0;\n  overflow: hidden;\n  transition: max-height 0.3s ease;\n}\n\n.trust-item.active .trust-content {\n  max-height: 200px;\n}\n\n.trust-content p {\n  margin: 0;\n  padding: 0 20px 18px 70px;\n  font-size: 14px;\n  font-weight: 400;\n  line-height: 1.7;\n  color: rgba(255,255,255,0.8);\n}\n</style>\n\n<script>\nfunction toggleAccordion(btn) {\n  var item = btn.parentElement;\n  var isActive = item.classList.contains('active');\n  \n  document.querySelectorAll('.trust-item').forEach(function(el) {\n    el.classList.remove('active');\n  });\n  \n  if (!isActive) {\n    item.classList.add('active');\n  }\n}\n</script>"

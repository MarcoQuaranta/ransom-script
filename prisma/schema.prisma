generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id             String                     @id @default(cuid())
  shop           String                     @unique
  accessToken    String
  scope          String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  name           String?
  clientId       String?
  clientSecret   String?
  tokenExpiresAt DateTime?
  geminiApiKey   String?
  metafieldCache MetafieldDefinitionCache[]
  products       Product[]

  @@index([shop])
}

model Product {
  id                  String   @id @default(cuid())
  shopifyProductId    String
  shopId              String
  title               String
  handle              String?
  price               Float?
  sku                 String?
  templateSuffix      String   @default("landing")
  metafields          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  hasMultipleVariants Boolean  @default(false)
  imagesCount         Int      @default(0)
  variantsCount       Int      @default(1)
  shop                Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopifyProductId])
}

model Template {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  structure Json
  sections  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model MetafieldDefinitionCache {
  id          String   @id @default(cuid())
  shopId      String
  namespace   String
  key         String
  name        String
  type        String
  description String?
  validations Json?
  cachedAt    DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, namespace, key])
  @@index([shopId])
}
